<% layout("/layouts/boilerplate") %>

<div class="row mt-4 mb-5">
  <div class="col-11 col-md-10 offset-1">
    <h3 class="mb-4 fw-bold">
      <i class="fa-solid fa-calendar-check me-2"></i>My Bookings
    </h3>
    <% if(bookings.length === 0) { %>
      <div class="text-center py-5">
        <i class="fa-regular fa-calendar-xmark" style="font-size:3rem; color:#bbb;"></i>
        <p class="mt-3 text-muted fs-5">No bookings yet.</p>
        <a href="/listings" class="btn btn-dark mt-2">Explore Listings</a>
      </div>
    <% } else { %>
      <div class="row g-4">
        <% for(let booking of bookings) { %>
          <% if(booking.listing) { %>
          <div class="col-12 col-md-6 col-lg-4">
            <div class="card shadow-sm p-2 p-md-4" style="border-radius:14px; border:none;">
              <img
                src="<%= booking.listing.image.url %>"
                class="card-img-top"
                style="height:180px; object-fit:cover;"
                alt="listing"
              />
              <div class="card-body">
                <h5 class="card-title mb-1"><%= booking.listing.title %></h5>
                <p class="text-muted mb-2" style="font-size:.88rem;">
                  <i class="fa-solid fa-location-dot me-1"></i>
                  <%= booking.listing.location %>, <%= booking.listing.country %>
                </p>
                <hr class="my-2" />
                <div class="row mb-1 align-items-center small">
                  <div class="col-5 text-muted">Check-in</div>
                  <div class="col-7 text-end fw-semibold">
                    <%= new Date(booking.checkIn).toDateString() %>
                  </div>
                </div>
                <div class="row mb-1 align-items-center small">
                  <div class="col-5 text-muted">Check-out</div>
                  <div class="col-7 text-end fw-semibold">
                    <%= new Date(booking.checkOut).toDateString() %>
                  </div>
                </div>
                <div class="row mb-1 align-items-center small">
                  <div class="col-5 text-muted">Nights</div>
                  <div class="col-7 text-end fw-semibold">
                    <%= booking.totalNights %>
                  </div>
                </div>
                <div class="row mb-1 align-items-center small">
                  <div class="col-5 text-muted">Amount Paid</div>
                  <div class="col-7 text-end fw-bold">
                    &#8377;<%= booking.totalPrice.toLocaleString("en-IN") %>
                  </div>
                </div>
                <div class="row mb-2 align-items-center small">
                  <div class="col-5 text-muted">Transaction ID</div>
                  <div class="col-7 text-end text-secondary text-break">
                    <%= booking.transactionId %>
                  </div>
                </div>
                <div class="mt-3">
                <div class="d-flex gap-2 mb-2">
                    <a href="/listings/<%= booking.listing._id %>" 
                    class="btn btn-outline-dark btn-sm flex-fill">
                    View Listing
                    </a>
                    <% if(new Date(booking.checkIn) > new Date()) { %>
                    <form method="POST" action="/bookings/<%= booking._id %>?_method=DELETE" class="flex-fill">
                        <button
                        type="submit"
                        class="btn btn-outline-danger btn-sm w-100"
                        onclick="return confirm('Cancel this booking?')"
                        >
                        Cancel
                        </button>
                    </form>
                    <% } else if(new Date(booking.checkOut) < new Date()) { %>
                    <span class="btn btn-sm btn-secondary flex-fill disabled">
                        Completed
                    </span>
                    <% } else { %>
                    <span class="btn btn-sm flex-fill disabled" style="background:#fe424d; color:white;">
                        Active Stay
                    </span>
                    <% } %>
                </div>
                <div class="d-flex">
                    <a href="/bookings/confirmation/<%= booking._id %>" 
                    class="btn btn-dark btn-sm w-100">
                    View Receipt
                    </a>
                </div>
                </div>
              </div>
            </div>
          </div>
          <% } %>
        <% } %>
      </div>
    <% } %>
  </div>
</div>
